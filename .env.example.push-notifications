# Frontend - Firebase Configuration (Push Notifications)
# Get these values from your Firebase Console at https://console.firebase.google.com

# Firebase API Key
VITE_FIREBASE_API_KEY=

# Firebase Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=

# Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=

# Firebase Messaging Sender ID (same as project number)
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Firebase App ID
VITE_FIREBASE_APP_ID=

# Firebase VAPID Public Key (for Web Push)
# Generate this in Firebase Project Settings > Cloud Messaging > Web Push Certificates
VITE_FIREBASE_VAPID_KEY=

# App Version (for device metadata)
VITE_APP_VERSION=1.0.0

# Backend Configuration (from backend .env)
VITE_API_BASE_URL=http://localhost:4000

# Firebase Project ID (backend)
FIREBASE_PROJECT_ID=

# Firebase Service Account Key (backend)
# Either JSON string or path to service account key file
FIREBASE_SERVICE_ACCOUNT_KEY=

# Enable/Disable Push Notifications
PUSH_NOTIFICATIONS_ENABLED=true
